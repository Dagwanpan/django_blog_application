{% extends 'base.html' %}

{% block content %}

<h2>⚠️ Confirm Delete</h2>

<p>Are you sure you want to delete this post?</p>

<div>
    <h3>{{ post.title }}</h3>
    <p>{{ post.content }}</p>
</div>

<form method="POST" style="display:inline;">
    {% csrf_token %}
    <button type="submit" style="color:red;">Yes, Delete</button>
</form>

<a href="{% url 'home' %}">
    <button>Cancel</button>
</a>

{% endblock %}